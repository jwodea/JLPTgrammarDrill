    {
      "id": "n5_004_1",
      "example_sentence": "猫がいます。",
      "translation": "There is a cat.",
      "blank_target": "が",
      "wrong_choices": [
        "を",
        "に",
        "で"
      ],
      "wrong_choice_explanations": [
        "を marks a direct object; います needs が for the subject that exists.",
        "に marks a location, not the thing that exists.",
        "で marks the place or means of an action, not the subject of existence."
      ],
      "hiragana_full": "ねこがいます。",
      "audio_alternatives": [
        {
          "kanji": "猫がいる。",
          "hiragana_full": "ねこがいる。"
        },
        {
          "kanji": "猫がおります。",
          "hiragana_full": "ねこがおります。"
        }
      ],
      "audio_eligible": true
    },
